# Skopiuj na .env i wpisz wartości produkcyjne. .env jest w .gitignore.

# Domena (musi mieć rekord A/AAAA → IP VM zanim odpalisz init-letsencrypt.sh).
DOMAIN=prostriker.online

# Email dla Let's Encrypt (notyfikacje o wygaśnięciu, recovery).
# Wpisz własny — używany TYLKO przez LE do alertów o wygasającym cercie.
EMAIL_LE=your-email@example.com

# 1 = staging Let's Encrypt (test, nieprawdziwy cert), 0 = produkcja.
# Najpierw odpal ze STAGING=1, sprawdź że certbot przechodzi, potem 0.
STAGING=0

# mp-server config — przekazywane jako env do kontenera.
NODE_ENV=production
PORT=3000
# Dopisz tu inne zmienne których wymaga socker-server (np. CORS_ORIGIN).
