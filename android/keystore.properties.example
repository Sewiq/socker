# Szablon dla android/keystore.properties (poza VCS — chroniony przez .gitignore).
# Skopiuj na keystore.properties i wpisz własne dane:
#   cp android/keystore.properties.example android/keystore.properties
#
# storeFile jest względny do katalogu `android/` (rootProject).
# Keystore trzymamy w głównym katalogu repo (~/Pobrane/socker/prostriker.keystore),
# więc względna ścieżka to `../prostriker.keystore`.

storeFile=../prostriker.keystore
storePassword=PUT_KEYSTORE_PASSWORD_HERE
keyAlias=prostriker
keyPassword=PUT_KEY_PASSWORD_HERE
